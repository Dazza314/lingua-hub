{
  "name": "@lingua-hub/android",
  "version": "0.0.0",
  "dependencies": {
    "@capacitor/android": "catalog:",
    "@capacitor/core": "catalog:",
    "@lingua-hub/capacitor-ankidroid": "workspace:*"
  },
  "devDependencies": {
    "@capacitor/cli": "catalog:"
  },
  "private": true,
  "scripts": {
    "build": "cd android && ANDROID_HOME=/mnt/c/Android ./gradlew assembleDebug",
    "forward": "/mnt/c/Android/platform-tools/adb.exe reverse tcp:3000 tcp:3000",
    "install:device": "/mnt/c/Android/platform-tools/adb.exe install android/app/build/outputs/apk/debug/app-debug.apk",
    "open": "cap open android",
    "run:device": "pnpm build && pnpm install:device && pnpm forward",
    "sync": "cap sync android"
  }
}
