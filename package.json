{
  "name": "lingua-hub",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "knip": "knip",
    "format": "eslint --fix .; prettier --write .",
    "format:check": "eslint .; prettier --check .",
    "gen:supabase-types": "supabase gen types typescript --linked > modules/supabase/src/database.types.ts",
    "db:push": "supabase db push"
  },
  "devDependencies": {
    "@eslint/compat": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "eslint": "catalog:",
    "eslint-config-next": "catalog:",
    "eslint-plugin-check-file": "catalog:",
    "eslint-plugin-no-barrel-files": "catalog:",
    "knip": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-curly": "catalog:",
    "supabase": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0"
}
