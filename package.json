{
  "name": "lingua-hub",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "knip": "knip",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "gen:supabase-types": "supabase gen types typescript --linked > modules/supabase/src/database.types.ts"
  },
  "devDependencies": {
    "@eslint/compat": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "eslint": "catalog:",
    "eslint-config-next": "catalog:",
    "eslint-plugin-check-file": "catalog:",
    "eslint-plugin-no-barrel-files": "catalog:",
    "knip": "catalog:",
    "prettier": "catalog:",
    "supabase": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0"
}
