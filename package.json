{
  "name": "lingua-hub",
  "devDependencies": {
    "@eslint/compat": "catalog:",
    "eslint": "catalog:",
    "eslint-config-next": "catalog:",
    "eslint-plugin-check-file": "catalog:",
    "eslint-plugin-no-barrel-files": "catalog:",
    "husky": "catalog:",
    "knip": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-curly": "catalog:",
    "supabase": "catalog:",
    "syncpack": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "db:push": "supabase db push",
    "dev": "turbo run dev",
    "check": "pnpm lint && pnpm format:check && pnpm syncpack:lint",
    "fix": "pnpm lint:fix; pnpm format; pnpm syncpack:format",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "gen:supabase-types": "supabase gen types typescript --linked > modules/supabase/src/database.types.ts",
    "knip": "knip",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "prepare": "husky",
    "syncpack:format": "syncpack format",
    "syncpack:lint": "syncpack lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "type": "module"
}
